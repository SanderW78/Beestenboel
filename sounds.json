<!doctype html><html lang="nl"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Beestenboel Contentmanager</title>
<style>
:root{--bg:#07111f;--panel:#101f35;--ink:#f8fbff;--muted:#9fb1c8;--a:#ffca3a;--b:#7b61ff;--ok:#32d583;--bad:#ff5c7a}*{box-sizing:border-box}body{margin:0;font-family:Inter,system-ui,sans-serif;background:radial-gradient(circle at 10% 0,#243b70 0,transparent 34%),var(--bg);color:var(--ink);min-height:100vh}main{width:min(1150px,94vw);margin:auto;padding:28px 0 60px}header{display:flex;justify-content:space-between;gap:20px;align-items:center;flex-wrap:wrap}h1{font-size:clamp(2rem,5vw,4rem);margin:0}.sub{color:var(--muted);max-width:720px}.btn,a.btn{border:0;border-radius:14px;padding:12px 17px;font-weight:900;cursor:pointer;background:var(--a);color:#111;text-decoration:none;display:inline-flex;align-items:center;gap:7px}.btn.alt{background:#263a58;color:#fff}.grid{display:grid;grid-template-columns:minmax(0,390px) minmax(0,1fr);gap:20px;margin-top:25px}.panel{background:rgba(16,31,53,.92);border:1px solid rgba(255,255,255,.1);border-radius:22px;padding:20px;box-shadow:0 20px 60px #0005}.drop{border:2px dashed #7890b4;border-radius:18px;padding:25px;text-align:center;cursor:pointer;background:#ffffff08}.drop.drag{border-color:var(--a);background:#ffca3a12}.drop strong{font-size:1.15rem}.fileinfo{color:var(--muted);margin-top:8px}.wave{width:100%;height:72px;background:#081421;border-radius:14px;margin:14px 0}label{display:block;color:var(--muted);font-size:.85rem;font-weight:800;margin:13px 0 6px}input,select{width:100%;padding:12px;border-radius:12px;border:1px solid #405473;background:#071421;color:#fff;font:inherit}.twocol{display:grid;grid-template-columns:1fr 1fr;gap:10px}.checks{display:flex;gap:18px;margin:15px 0;flex-wrap:wrap}.checks label{margin:0;color:#fff}.checks input{width:auto}.actions{display:flex;gap:9px;flex-wrap:wrap}.status{margin:14px 0;padding:11px;border-radius:12px;background:#ffffff0a;color:var(--muted)}.list{display:grid;gap:10px}.item{display:grid;grid-template-columns:55px 1fr auto;gap:12px;align-items:center;background:#081421;border:1px solid #263c5a;border-radius:16px;padding:12px}.emoji{font-size:2rem;text-align:center}.meta{color:var(--muted);font-size:.85rem;margin-top:4px}.tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}.tag{font-size:.72rem;border-radius:999px;padding:4px 8px;background:#213755}.item button{border:0;background:#263a58;color:#fff;border-radius:9px;padding:8px;cursor:pointer}.toolbar{display:flex;gap:9px;flex-wrap:wrap;margin-bottom:14px}.empty{color:var(--muted);text-align:center;padding:45px 10px}@media(max-width:850px){.grid{grid-template-columns:1fr}.item{grid-template-columns:45px 1fr}.item .item-actions{grid-column:1/-1}.twocol{grid-template-columns:1fr}}</style>
<style id="phase1-brand-manager">
:root{--gold:#F6C453;--cream:#FFF3D2;--purple:#35114D;--night:#080611}
body{font-family:'Montserrat',system-ui,sans-serif!important;color:var(--cream)!important;background:radial-gradient(circle at 50% -10%,rgba(246,196,83,.15),transparent 30%),radial-gradient(circle at 15% 15%,rgba(125,58,177,.24),transparent 34%),linear-gradient(145deg,#07050d,#160a24 54%,#090612)!important}
h1,h2,h3,button{font-family:'Bebas Neue','Arial Narrow',sans-serif!important;letter-spacing:.05em}
.card,.panel,section{border-color:rgba(246,196,83,.25)!important;box-shadow:0 22px 65px rgba(0,0,0,.45)!important}
button.primary,.primary{background:linear-gradient(145deg,#FFD66F,#E99527)!important;color:#2B1605!important;border-color:#FFE7A4!important}
button:not(.primary){border-color:rgba(246,196,83,.27)!important}
h1{color:var(--gold)!important;text-shadow:0 0 25px rgba(246,196,83,.25)}
</style>
</head>
<body><main><header><div><h1>🎛️ Geluidenstudio</h1><p class="sub">Voeg mp3’s toe, geef ze spelmetadata en sla ze rechtstreeks op in Beestenboel. De bibliotheek wordt lokaal in deze browser bewaard.</p></div><a class="btn" href="index.html">▶ Open het spel</a></header>
<div class="grid"><section class="panel"><h2>Geluid toevoegen</h2><div id="drop" class="drop"><strong>Sleep een mp3 hierheen</strong><div>of klik om een bestand te kiezen</div><div id="fileinfo" class="fileinfo">Nog geen bestand gekozen</div><input id="file" type="file" accept="audio/*" hidden></div><audio id="preview" controls style="width:100%;margin-top:14px"></audio><canvas id="wave" class="wave" width="700" height="120"></canvas>
<label>Naam</label><input id="name" placeholder="Bijvoorbeeld Chewbacca"><div class="twocol"><div><label>Emoji</label><input id="emoji" value="🎬"></div><div><label>Categorie</label><select id="category"><option value="dieren">Dieren</option><option value="mensen">Mens &amp; stem</option><option value="performance">Muziek &amp; performance</option><option value="films">Films &amp; tv</option><option value="games">Games</option></select></div></div>
<div class="twocol"><div><label>Moeilijkheid (1–5)</label><input id="difficulty" type="number" min="1" max="5" value="3"></div><div><label>Lachfactor (1–10)</label><input id="fun" type="number" min="1" max="10" value="8"></div></div><div class="twocol"><div><label>Fragment start (sec.)</label><input id="trimStart" type="number" min="0" step="0.1" value="0"></div><div><label>Fragment einde (sec.)</label><input id="trimEnd" type="number" min="0" step="0.1" value="0"></div></div>
<div class="checks"><label><input id="legendary" type="checkbox"> Legendary</label><label><input id="modifiers" type="checkbox" checked> Chaosmodifiers</label></div><div id="status" class="status">Kies eerst een audiobestand.</div><div class="actions"><button id="save" class="btn">＋ Opslaan</button><button id="reset" class="btn alt">Leegmaken</button></div></section>
<section class="panel"><div class="toolbar"><button id="export" class="btn alt">⬇ Exporteer bibliotheek</button><button id="importBtn" class="btn alt">⬆ Importeer</button><input id="importFile" type="file" accept="application/json" hidden><button id="clear" class="btn alt">🗑 Wis eigen bibliotheek</button></div><h2>Eigen geluiden <span id="count"></span></h2><div id="list" class="list"></div></section></div></main>
<script>
const DB='beestenboel-content-v1'; let selectedFile=null, editingId=null;
const $=id=>document.getElementById(id);
function openDB(){return new Promise((res,rej)=>{const r=indexedDB.open(DB,1);r.onupgradeneeded=()=>{if(!r.result.objectStoreNames.contains('sounds'))r.result.createObjectStore('sounds',{keyPath:'id'})};r.onsuccess=()=>res(r.result);r.onerror=()=>rej(r.error)})}
async function all(){const db=await openDB();return new Promise((res,rej)=>{const r=db.transaction('sounds').objectStore('sounds').getAll();r.onsuccess=()=>res(r.result||[]);r.onerror=()=>rej(r.error)})}
async function put(v){const db=await openDB();return new Promise((res,rej)=>{const r=db.transaction('sounds','readwrite').objectStore('sounds').put(v);r.onsuccess=()=>res();r.onerror=()=>rej(r.error)})}
async function del(id){const db=await openDB();return new Promise((res,rej)=>{const r=db.transaction('sounds','readwrite').objectStore('sounds').delete(id);r.onsuccess=()=>res();r.onerror=()=>rej(r.error)})}
function slug(s){return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,'_').replace(/^_|_$/g,'')+'_'+Date.now().toString(36)}
function dataURL(blob){return new Promise((res,rej)=>{const r=new FileReader;r.onload=()=>res(r.result);r.onerror=()=>rej(r.error);r.readAsDataURL(blob)})}
function dataToBlob(url){const [h,b]=url.split(',');const mime=(h.match(/:(.*?);/)||[])[1]||'audio/mpeg';const bin=atob(b);const a=new Uint8Array(bin.length);for(let i=0;i<bin.length;i++)a[i]=bin.charCodeAt(i);return new Blob([a],{type:mime})}
async function pick(file){selectedFile=file;$('fileinfo').textContent=`${file.name} · ${(file.size/1024).toFixed(0)} kB`;$('preview').src=URL.createObjectURL(file);$('status').textContent='Vul de metadata in en luister eventueel terug.';$('name').value=$('name').value||file.name.replace(/\.[^.]+$/,'').replace(/[_-]+/g,' ');$('preview').onloadedmetadata=()=>{$('trimEnd').value=$('preview').duration.toFixed(1);drawWave(file)}}
async function drawWave(file){try{const ac=new AudioContext();const buf=await ac.decodeAudioData(await file.arrayBuffer());const d=buf.getChannelData(0),c=$('wave'),x=c.getContext('2d');x.clearRect(0,0,c.width,c.height);x.strokeStyle='#ffca3a';x.lineWidth=3;x.beginPath();const step=Math.ceil(d.length/c.width);for(let i=0;i<c.width;i++){let min=1,max=-1;for(let j=0;j<step;j++){const v=d[i*step+j]||0;min=Math.min(min,v);max=Math.max(max,v)}x.moveTo(i,(1+min)*c.height/2);x.lineTo(i,(1+max)*c.height/2)}x.stroke();ac.close()}catch(e){}}
async function render(){const rows=await all();$('count').textContent=`(${rows.length})`;$('list').innerHTML=rows.length?'':'<div class="empty">Nog geen eigen geluiden. De meegeleverde geluiden staan al permanent in het spel.</div>';rows.sort((a,b)=>a.naam.localeCompare(b.naam)).forEach(r=>{const d=document.createElement('div');d.className='item';d.innerHTML=`<div class="emoji">${r.emoji||'🎧'}</div><div><strong>${r.naam}</strong><div class="meta">${r.cat} · moeilijkheid ${r.difficulty||3} · lachfactor ${r.fun||8}</div><div class="tags">${r.legendary?'<span class="tag">Legendary</span>':''}${r.modifierAllowed?'<span class="tag">Chaos</span>':''}</div></div><div class="item-actions"><button data-play>▶</button> <button data-edit>✏️</button> <button data-del>🗑</button></div>`;d.querySelector('[data-play]').onclick=()=>{const a=new Audio(URL.createObjectURL(r.audioBlob));a.currentTime=r.trimStart||0;a.play();if(r.trimEnd)setTimeout(()=>a.pause(),Math.max(0,(r.trimEnd-(r.trimStart||0))*1000))};d.querySelector('[data-del]').onclick=async()=>{if(confirm(`Verwijder ${r.naam}?`)){await del(r.id);render()}};d.querySelector('[data-edit]').onclick=()=>edit(r);$('list').appendChild(d)})}
function edit(r){editingId=r.id;selectedFile=r.audioBlob;$('name').value=r.naam;$('emoji').value=r.emoji;$('category').value=r.cat;$('difficulty').value=r.difficulty;$('fun').value=r.fun;$('trimStart').value=r.trimStart||0;$('trimEnd').value=r.trimEnd||0;$('legendary').checked=!!r.legendary;$('modifiers').checked=r.modifierAllowed!==false;$('preview').src=URL.createObjectURL(r.audioBlob);$('fileinfo').textContent='Bestaand geluid bewerken';$('save').textContent='Wijzigingen opslaan';window.scrollTo({top:0,behavior:'smooth'})}
function reset(){selectedFile=null;editingId=null;$('file').value='';$('name').value='';$('emoji').value='🎬';$('difficulty').value=3;$('fun').value=8;$('trimStart').value=0;$('trimEnd').value=0;$('legendary').checked=false;$('modifiers').checked=true;$('preview').removeAttribute('src');$('fileinfo').textContent='Nog geen bestand gekozen';$('save').textContent='＋ Opslaan';$('status').textContent='Kies eerst een audiobestand.';$('wave').getContext('2d').clearRect(0,0,700,120)}
$('save').onclick=async()=>{const naam=$('name').value.trim();if(!selectedFile||!naam){$('status').textContent='Audiobestand en naam zijn verplicht.';return}const row={id:editingId||slug(naam),naam,emoji:$('emoji').value||'🎧',cat:$('category').value,difficulty:+$('difficulty').value||3,fun:+$('fun').value||8,trimStart:+$('trimStart').value||0,trimEnd:+$('trimEnd').value||0,legendary:$('legendary').checked,modifierAllowed:$('modifiers').checked,audioBlob:selectedFile,custom:true,updatedAt:new Date().toISOString()};await put(row);$('status').textContent=`${naam} is opgeslagen en direct beschikbaar in het spel.`;reset();render()};
$('reset').onclick=reset;$('drop').onclick=()=>$('file').click();$('file').onchange=e=>e.target.files[0]&&pick(e.target.files[0]);['dragenter','dragover'].forEach(n=>$('drop').addEventListener(n,e=>{e.preventDefault();$('drop').classList.add('drag')}));['dragleave','drop'].forEach(n=>$('drop').addEventListener(n,e=>{e.preventDefault();$('drop').classList.remove('drag')}));$('drop').addEventListener('drop',e=>e.dataTransfer.files[0]&&pick(e.dataTransfer.files[0]));
$('export').onclick=async()=>{const rows=await all();const out=[];for(const r of rows){const c={...r,audioData:await dataURL(r.audioBlob)};delete c.audioBlob;out.push(c)}const blob=new Blob([JSON.stringify({version:1,exportedAt:new Date().toISOString(),sounds:out},null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='beestenboel-eigen-geluiden.json';a.click()};
$('importBtn').onclick=()=>$('importFile').click();$('importFile').onchange=async e=>{const obj=JSON.parse(await e.target.files[0].text());for(const r of obj.sounds||[]){r.audioBlob=dataToBlob(r.audioData);delete r.audioData;await put(r)}render();alert('Bibliotheek geïmporteerd.')};
$('clear').onclick=async()=>{if(!confirm('Alle zelf toegevoegde geluiden wissen?'))return;const db=await openDB();await new Promise((res,rej)=>{const r=db.transaction('sounds','readwrite').objectStore('sounds').clear();r.onsuccess=res;r.onerror=rej});render()};render();
</script></body></html>